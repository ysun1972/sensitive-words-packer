{
  "_comment": "演示规则集。注意：中文场景下 \\b 不能匹配中文与数字之间的边界，建议使用 (?<!\\d) 和 (?!\\d) 替代；如需在纯英文/数字边界工作可直接用 \\b。",
  "rules": [
    {
      "name": "中国大陆手机号",
      "pattern": "(?<!\\d)1[3-9]\\d{9}(?!\\d)",
      "replacement": "[手机号]"
    },
    {
      "name": "电子邮箱",
      "pattern": "[\\w.+-]+@[\\w.-]+\\.[A-Za-z]{2,}",
      "replacement": "[邮箱]"
    },
    {
      "name": "18 位身份证号",
      "pattern": "(?<!\\d)\\d{17}[\\dXx](?!\\d)",
      "replacement": "[身份证]"
    },
    {
      "name": "银行卡号（16-19 位）",
      "pattern": "(?<!\\d)\\d{16,19}(?!\\d)",
      "replacement": "[银行卡]"
    },
    {
      "name": "IPv4 地址",
      "pattern": "(?<!\\d)(?:\\d{1,3}\\.){3}\\d{1,3}(?!\\d)",
      "replacement": "[IP]"
    }
  ]
}
